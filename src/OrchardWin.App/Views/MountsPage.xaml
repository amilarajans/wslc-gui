<Page
    x:Class="OrchardWin.App.Views.MountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <!-- Matches Orchard Mounts.png: list (search + in-use) | detail (header, Overview, Technical, Used By). -->
    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="240" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <!-- LIST -->
        <Grid Grid.Column="0" Padding="12,12,8,12" RowSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         PlaceholderText="Search mounts"
                         TextChanged="OnSearchTextChanged" />
                <!-- Orchard: line.3.horizontal.decrease.circle — filter mounts in use -->
                <ToggleButton x:Name="InUseFilterButton" Grid.Column="1" Padding="10,6"
                              Click="OnInUseFilterClick"
                              ToolTipService.ToolTip="Show only mounts used by running containers">
                    <FontIcon Glyph="&#xE71C;" FontSize="14" />
                </ToggleButton>
            </Grid>

            <Grid Grid.Row="1">
                <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <ProgressRing IsActive="True" Width="28" Height="28" />
                    <TextBlock Text="Loading mounts..." Opacity="0.55" FontSize="12" />
                </StackPanel>

                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="36" Opacity="0.35" HorizontalAlignment="Center" />
                    <TextBlock Text="No Mounts" FontSize="15" FontWeight="SemiBold" Opacity="0.6"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptyHintText"
                               Text="Mounts appear when containers use -v / bind volumes"
                               FontSize="12" Opacity="0.5" HorizontalAlignment="Center"
                               TextWrapping="WrapWholeWords" TextAlignment="Center" MaxWidth="240" />
                </StackPanel>

                <ListView x:Name="MountsList" Visibility="Collapsed" SelectionMode="Single"
                          SelectionChanged="OnSelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MountRow">
                            <!-- Orchard ListItemRow: externaldrive + destination primary + source secondary -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="18" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                              Visibility="{x:Bind RunningIconVisibility}" />
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Visibility="{x:Bind IdleIconVisibility}" />
                                </Grid>
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Destination}" FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind SourceDisplay}" FontSize="11" Opacity="0.5"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Copy Source Path" Click="OnCopySourceMenuClick" />
                            <MenuFlyoutItem Text="Copy Destination Path" Click="OnCopyDestinationMenuClick" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                </ListView>
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- DETAIL -->
        <Grid Grid.Column="2">
            <StackPanel x:Name="EmptyDetail" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8B7;" FontSize="48" Opacity="0.3" HorizontalAlignment="Center" />
                <TextBlock Text="Select a mount" Opacity="0.55" HorizontalAlignment="Center" />
            </StackPanel>

            <Grid x:Name="DetailRoot" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: title (source leaf) + Open in Explorer — Orchard MountDetailHeader -->
                <Grid Grid.Row="0" Padding="20,18,16,14" ColumnSpacing="12"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DetailNameText" Grid.Column="0" FontSize="22" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <Button x:Name="OpenSourceButton" Grid.Column="1" Click="OnOpenSourceClick"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                            <TextBlock Text="Open in Explorer" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" Padding="20,16,20,28">
                    <StackPanel Spacing="22">
                        <!-- Overview — flat rows like Orchard CopyableInfoRow / InfoRow -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Overview" FontSize="15" FontWeight="SemiBold" />
                            <StackPanel Spacing="0">
                                <Grid Padding="0,7" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Source" Opacity="0.55" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SourceText" Grid.Column="1" FontSize="13"
                                               FontFamily="Cascadia Mono,Consolas"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <HyperlinkButton x:Name="CopySourceButton" Grid.Column="2"
                                                     Content="Copy" FontSize="12"
                                                     Click="OnCopySourceClick"
                                                     VerticalAlignment="Center" />
                                </Grid>
                                <Grid Padding="0,7" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Destination" Opacity="0.55" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="DestinationText" Grid.Column="1" FontSize="13"
                                               FontFamily="Cascadia Mono,Consolas"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <HyperlinkButton x:Name="CopyDestinationButton" Grid.Column="2"
                                                     Content="Copy" FontSize="12"
                                                     Click="OnCopyDestinationClick"
                                                     VerticalAlignment="Center" />
                                </Grid>
                                <Grid Padding="0,7" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Type" Opacity="0.55" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="TypeText" Grid.Column="1" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <HyperlinkButton x:Name="CopyTypeButton" Grid.Column="2"
                                                     Content="Copy" FontSize="12"
                                                     Click="OnCopyTypeClick"
                                                     VerticalAlignment="Center" />
                                </Grid>
                                <Grid Padding="0,7" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Containers" Opacity="0.55" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="ContainerCountText" Grid.Column="1" FontSize="13"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Grid x:Name="OptionsRow" Padding="0,7" ColumnSpacing="16"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Options" Opacity="0.55" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="OptionsText" Grid.Column="1" FontSize="13"
                                               FontFamily="Cascadia Mono,Consolas"
                                               IsTextSelectionEnabled="True"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Technical Details -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Technical Details" FontSize="15" FontWeight="SemiBold" />
                            <Grid Padding="0,7" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Filesystem" Opacity="0.55" FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="FilesystemText" Grid.Column="1" FontSize="13"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <!-- Used By Containers — Container | IP Address | Hostname -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Used By Containers" FontSize="15" FontWeight="SemiBold" />
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="0">
                                <StackPanel>
                                    <Grid x:Name="UsersHeader" ColumnSpacing="8"
                                          Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Container" FontSize="12"
                                                   FontWeight="SemiBold" Opacity="0.7" />
                                        <TextBlock Grid.Column="1" Text="IP Address" FontSize="12"
                                                   FontWeight="SemiBold" Opacity="0.7" />
                                        <TextBlock Grid.Column="2" Text="Hostname" FontSize="12"
                                                   FontWeight="SemiBold" Opacity="0.7" />
                                    </Grid>
                                    <StackPanel x:Name="UsersHost" Spacing="0" />
                                    <TextBlock x:Name="UsersEmptyText"
                                               Text="No containers are currently using this mount"
                                               Opacity="0.55" FontSize="13"
                                               Padding="12,14" Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
