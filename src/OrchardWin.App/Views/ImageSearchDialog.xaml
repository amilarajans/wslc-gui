<ContentDialog
    x:Class="OrchardWin.App.Views.ImageSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:OrchardWin.App.Views"
    mc:Ignorable="d"
    Title="Search Container Images"
    CloseButtonText="Close"
    DefaultButton="Close"
    MinWidth="900"
    Width="900"
    MinHeight="620">

    <Grid RowSpacing="12" Width="860">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="380" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Search Docker Hub for container images to download"
                   Opacity="0.7" FontSize="12" />

        <!-- Search bar -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="QueryBox" Grid.Column="0"
                     PlaceholderText="Search for images (e.g., nginx, postgres, alpine)..."
                     TextChanged="QueryBox_TextChanged" KeyDown="QueryBox_KeyDown" />
            <Button x:Name="SearchButton" Grid.Column="1" Content="Search" Click="SearchButton_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <!-- Results area: exactly one of these four states is visible at a time, mirroring
             ImageSearchView.swift's emptySearchState/loadingState/searchResultsList/noResultsState
             branch. -->
        <Grid Grid.Row="2">
            <StackPanel x:Name="QuickSearchPanel" Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Find and download images from Docker Hub" Opacity="0.7"
                           HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Popular:" Opacity="0.6" VerticalAlignment="Center" />
                    <Button Content="nginx" Tag="nginx" Click="QuickSearch_Click" />
                    <Button Content="postgres" Tag="postgres" Click="QuickSearch_Click" />
                    <Button Content="redis" Tag="redis" Click="QuickSearch_Click" />
                    <Button Content="alpine" Tag="alpine" Click="QuickSearch_Click" />
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="SearchingPanel" Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed">
                <ProgressRing x:Name="SearchingRing" IsActive="False" Width="36" Height="36" HorizontalAlignment="Center" />
                <TextBlock Text="Searching for images..." Opacity="0.7" />
            </StackPanel>

            <TextBlock x:Name="NoResultsText" Text="No results found - try a different search term"
                       Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

            <ScrollViewer x:Name="ResultsScroller" Visibility="Collapsed">
                <GridView x:Name="ResultsGrid" SelectionMode="None" IsItemClickEnabled="False">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:SearchResultRow">
                            <Border Width="270" Height="150" Padding="12" CornerRadius="6" Margin="4"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="{x:Bind BadgeGlyph}" FontSize="16" Foreground="{x:Bind BadgeColor}" />
                                        <StackPanel Spacing="0">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="13"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="190" />
                                            <TextBlock Text="{x:Bind MetaText}" FontSize="10" Opacity="0.7" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Text="{x:Bind Description}" FontSize="11" Opacity="0.75"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="3" />

                                    <Grid Grid.Row="2">
                                        <ProgressRing IsActive="{x:Bind IsPulling}" Visibility="{x:Bind IsPulling}"
                                                      Width="22" Height="22" HorizontalAlignment="Center" />
                                        <Button Content="Pull" Tag="{x:Bind Name}" Click="PullButton_Click"
                                                HorizontalAlignment="Stretch" Visibility="{x:Bind ShowPullButton}"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        <Button Content="Already downloaded" IsEnabled="False"
                                                HorizontalAlignment="Stretch" Visibility="{x:Bind IsAlreadyPulled}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </ScrollViewer>
        </Grid>

        <!-- Active downloads, mirrors ImageSearchView.swift's activePullsSection -->
        <StackPanel x:Name="ActivePullsPanel" Grid.Row="3" Spacing="8" Visibility="Collapsed">
            <TextBlock Text="Active Downloads" FontWeight="SemiBold" Opacity="0.8" />
            <ItemsControl x:Name="ActivePullsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:PullProgressDisplay">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6"
                                Padding="10" Margin="0,0,0,6">
                            <StackPanel Spacing="6">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind StatusGlyph}" Foreground="{x:Bind StatusColor}" />
                                    <StackPanel Grid.Column="1" Spacing="0">
                                        <TextBlock Text="{x:Bind ImageName}" FontWeight="Medium" FontSize="13" />
                                        <TextBlock Text="{x:Bind Message}" FontSize="11" Opacity="0.7" />
                                    </StackPanel>
                                    <ProgressRing Grid.Column="2" IsActive="{x:Bind IsPulling}" Width="16" Height="16" />
                                </Grid>
                                <ProgressBar Value="{x:Bind ProgressPercent}" Maximum="100" Visibility="{x:Bind IsPulling}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</ContentDialog>
