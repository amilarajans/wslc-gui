<Page
    x:Class="OrchardWin.App.Views.ImagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Page.Resources>

    <!-- Orchard Images: list | detail (header + Overview/Technical + Configuration + Used By). -->
    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="240" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <!-- LIST PANE -->
        <Grid Grid.Column="0" Padding="12,12,8,12" RowSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         PlaceholderText="Search images"
                         TextChanged="SearchBox_TextChanged" />
                <ToggleButton x:Name="InUseFilterButton" Grid.Column="1" Padding="8,6"
                              ToolTipService.ToolTip="Show only images in use"
                              Click="InUseFilterButton_Click">
                    <FontIcon Glyph="&#xE71C;" FontSize="14" />
                </ToggleButton>
                <Button Grid.Column="2" Padding="8,6" Click="SortDirectionButton_Click"
                        ToolTipService.ToolTip="Toggle sort direction">
                    <FontIcon x:Name="SortDirectionGlyph" Glyph="&#xE74A;" FontSize="14" />
                </Button>
                <Button Grid.Column="3" Padding="8,6" Click="SearchDockerHubButton_Click"
                        ToolTipService.ToolTip="Search Docker Hub / pull image">
                    <!-- SF: plus -->
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <ListView x:Name="ImagesListView"
                          SelectionMode="Single"
                          SelectionChanged="ImagesListView_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,8" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ImageRow">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- SF: cube.transparent — green when used by a running container -->
                                <Grid Grid.Column="0" Width="20" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE81E;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                              Visibility="{x:Bind RunningIconVisibility}" />
                                    <FontIcon Glyph="&#xE81E;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Visibility="{x:Bind IdleIconVisibility}" />
                                </Grid>
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Tag}" FontSize="11" Opacity="0.55"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Cascadia Mono,Consolas" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeText}" FontSize="11"
                                           Opacity="0.5" VerticalAlignment="Center"
                                           FontFamily="Cascadia Mono,Consolas" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Copy Image Reference" Click="OnCopyReferenceClick" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Remove Image" Click="OnRemoveImageClick" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                </ListView>

                <ProgressRing x:Name="ImagesLoadingRing" IsActive="False" Width="28" Height="28"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0" />
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- DETAIL PANE -->
        <Grid Grid.Column="2">
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <FontIcon Glyph="&#xE81E;" FontSize="48" Opacity="0.35" HorizontalAlignment="Center" />
                <TextBlock Text="Select an image" Opacity="0.55" HorizontalAlignment="Center" FontSize="14" />
            </StackPanel>

            <Grid x:Name="DetailRoot" Visibility="Collapsed" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: name + Launch / Delete (ImageDetailHeader) -->
                <Grid Grid.Row="0" Padding="20,16,16,12" ColumnSpacing="12"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DetailNameText" Grid.Column="0" FontSize="20" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="RunButton" Content="Launch image" Click="RunButton_Click" />
                        <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                Background="{ThemeResource SystemFillColorCriticalBrush}" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" Padding="16,16,16,24">
                    <StackPanel Spacing="16">
                        <InfoBar x:Name="InspectionErrorBar" Severity="Error" IsClosable="False" IsOpen="False" />

                        <StackPanel x:Name="InspectingPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                            <ProgressRing x:Name="InspectingRing" IsActive="False" Width="18" Height="18" />
                            <TextBlock Text="Inspecting image..." Opacity="0.6" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>

                        <!-- Overview | Technical Details -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource DetailCardStyle}">
                                <StackPanel x:Name="OverviewHost" Spacing="8" />
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource DetailCardStyle}">
                                <StackPanel x:Name="TechnicalHost" Spacing="8" />
                            </Border>
                        </Grid>

                        <!-- Configuration (from inspect variants) -->
                        <StackPanel x:Name="ConfigurationHost" Spacing="12" />

                        <!-- Used By Containers -->
                        <Border Style="{StaticResource DetailCardStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Used By Containers" FontSize="14" FontWeight="SemiBold" />
                                <Grid x:Name="UsersHeader" ColumnSpacing="8" Padding="4,0,4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Container" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                                    <TextBlock Grid.Column="1" Text="IP Address" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                                    <TextBlock Grid.Column="2" Text="Hostname" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                                </Grid>
                                <StackPanel x:Name="UsersHost" Spacing="0" />
                                <TextBlock x:Name="UsersEmptyText"
                                           Text="No containers are currently using this image"
                                           Opacity="0.55" FontSize="13" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
