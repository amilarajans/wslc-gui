<Page
    x:Class="OrchardWin.App.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <!--
        Reduced-scope port of Orchard's MultiLogView: a single log pane rather than the
        original's split-pane multi-pane windowing (see ARCHITECTURE.md / this port's task
        notes) - one target picker, one filter bar, one scrolling log view. Behavior within
        that one pane (default-to-first-running-container, ~2s poll, client-side filter,
        drop stale in-flight fetches) is kept 1:1 via LogsViewModel.
    -->
    <Grid Padding="20,20,20,0" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Log Viewer" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" x:Name="TargetCombo" HorizontalAlignment="Left" MinWidth="240"
                      SelectionChanged="OnTargetChanged" DisplayMemberPath="DisplayText" />
            <Button Grid.Column="2" x:Name="PauseButton" Click="OnPauseClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon x:Name="PauseIcon" Glyph="&#xE769;" FontSize="13" />
                    <TextBlock x:Name="PauseButtonText" Text="Pause" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="FilterBox" PlaceholderText="Filter logs..." TextChanged="OnFilterChanged" />
            <TextBlock Grid.Column="1" x:Name="MatchCountText" Opacity="0.65" FontSize="12" VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="2" Background="#D9000000" CornerRadius="4" Margin="0,4,0,20">
            <Grid>
                <TextBlock x:Name="EmptyStateText" Text="Select a container or machine above"
                           Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer x:Name="LogScroller">
                    <ItemsControl x:Name="LogLinesControl" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                                           Foreground="#D9FFFFFF" TextWrapping="NoWrap" IsTextSelectionEnabled="True" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
