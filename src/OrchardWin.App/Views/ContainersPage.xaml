<Page
    x:Class="OrchardWin.App.Views.ContainersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:OrchardWin.App.Controls"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="16" ColumnSpacing="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <InfoBar x:Name="AlertBar"
                 Grid.Row="0" Grid.ColumnSpan="2"
                 Severity="Error"
                 IsOpen="False"
                 IsClosable="True"
                 CloseButtonClick="OnAlertBarClose" />

        <!-- List pane -->
        <Grid Grid.Row="1" Grid.Column="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Containers" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" x:Name="RunButton" Click="OnRunClick" ToolTipService.ToolTip="Run a new container">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock Text="Run" />
                    </StackPanel>
                </Button>
            </Grid>

            <TextBox Grid.Row="1" x:Name="SearchBox" PlaceholderText="Search containers"
                     TextChanged="OnSearchTextChanged" />

            <Grid Grid.Row="2" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ToggleSwitch Grid.Column="0" x:Name="RunningOnlyToggle"
                              OnContent="Running only" OffContent="All containers"
                              Toggled="OnRunningOnlyToggled" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" x:Name="SortCombo" Width="100" SelectionChanged="OnSortChanged">
                    <ComboBoxItem Content="Name" Tag="Name" IsSelected="True" />
                    <ComboBoxItem Content="Status" Tag="Status" />
                    <ComboBoxItem Content="Image" Tag="Image" />
                </ComboBox>
            </Grid>

            <ListView Grid.Row="3" x:Name="ContainersListView"
                      SelectionMode="Extended"
                      SelectionChanged="OnSelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ContainerRowVm">
                        <controls:ListItemRow
                            Icon="&#xE7B8;"
                            IconColor="{x:Bind IconColor}"
                            PrimaryText="{x:Bind PrimaryText}"
                            SecondaryLeftText="{x:Bind SecondaryLeftText}"
                            SecondaryRightText="{x:Bind SecondaryRightText}"
                            ShowSandboxBadge="{x:Bind ShowSandboxBadge}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ContextFlyout>
                    <MenuFlyout x:Name="RowContextMenu" Opening="OnContextMenuOpening" />
                </ListView.ContextFlyout>
            </ListView>
        </Grid>

        <!-- Detail pane -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="EmptyState" Grid.Row="0" Grid.RowSpan="2"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE7B8;" FontSize="40" Opacity="0.4" HorizontalAlignment="Center" />
                <TextBlock Text="Select a container" Opacity="0.6" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="DetailRoot" Grid.Row="0" Visibility="Collapsed" Spacing="12" Padding="4,0,0,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon x:Name="DetailIcon" Grid.Column="0" Glyph="&#xE7B8;" FontSize="24" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="DetailNameText" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="DetailStatusText" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="StartButton" Click="OnStartClick" ToolTipService.ToolTip="Start container">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE768;" FontSize="12" />
                            <TextBlock Text="Start" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton" Click="OnStopClick" ToolTipService.ToolTip="Stop container">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE71A;" FontSize="12" />
                            <TextBlock Text="Stop" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ForceStopButton" Click="OnForceStopClick" ToolTipService.ToolTip="Force stop (SIGKILL)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            <TextBlock Text="Force Stop" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TerminalButton" Click="OnTerminalClick" ToolTipService.ToolTip="Open a terminal shell">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE756;" FontSize="12" />
                            <TextBlock Text="Terminal" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RemoveButton" Click="OnRemoveClick" ToolTipService.ToolTip="Remove container">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                            <TextBlock Text="Remove" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1" x:Name="DetailScroller" Visibility="Collapsed">
                <StackPanel x:Name="DetailContent" Spacing="16" Padding="4,4,4,24" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
