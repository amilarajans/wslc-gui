<Page
    x:Class="OrchardWin.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:OrchardWin.App.Controls"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Dashboard" FontSize="24" FontWeight="SemiBold" />

        <!-- Disk usage tiles -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <controls:StatTile Grid.Column="0" x:Name="ContainersTile" Icon="&#xE7B8;" Title="Containers" />
            <controls:StatTile Grid.Column="1" x:Name="ImagesTile" Icon="&#xE91B;" Title="Images" />
            <controls:StatTile Grid.Column="2" x:Name="VolumesTile" Icon="&#xE8A2;" Title="Volumes" />
            <controls:StatTile Grid.Column="3" x:Name="ReclaimableTile" Icon="&#xE74D;" Title="Reclaimable" />
        </Grid>

        <InfoBar Grid.Row="2" x:Name="UnavailableBar" Severity="Warning" Title="Stats Unavailable"
                 Message="Running containers were found but no statistics came back - check that the WSL container service is up to date and running."
                 IsOpen="False" IsClosable="False" />

        <ScrollViewer Grid.Row="3">
            <StackPanel Spacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Container Utilisation" FontSize="16" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8" Padding="6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="1" Text="Status" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="2" Text="CPU" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="3" Text="Memory" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="4" Text="Network" Opacity="0.6" FontSize="12" />
                        <TextBlock Grid.Column="5" Text="Disk" Opacity="0.6" FontSize="12" />
                    </Grid>
                    <ListView x:Name="ContainerRowsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:UtilisationRow">
                                <Grid ColumnSpacing="8" Padding="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Status}" Opacity="0.7" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                        <controls:Sparkline Values="{x:Bind CpuHistory}" Width="40" Height="18" StrokeColor="DodgerBlue" />
                                        <TextBlock Text="{x:Bind CpuPercentText}" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                        <controls:Sparkline Values="{x:Bind MemoryHistory}" Width="40" Height="18" StrokeColor="MediumPurple" />
                                        <TextBlock Text="{x:Bind MemoryPercentText}" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                                    </StackPanel>
                                    <controls:Sparkline Grid.Column="4" Values="{x:Bind NetworkHistory}" Width="50" Height="18" StrokeColor="SeaGreen" />
                                    <controls:Sparkline Grid.Column="5" Values="{x:Bind DiskHistory}" Width="50" Height="18" StrokeColor="Chocolate" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel x:Name="MachineSection" Spacing="8" Visibility="Collapsed">
                    <TextBlock Text="Machine Utilisation" FontSize="16" FontWeight="SemiBold" />
                    <ListView x:Name="MachineRowsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:UtilisationRow">
                                <Grid ColumnSpacing="8" Padding="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Status}" Opacity="0.7" />
                                    <controls:Sparkline Grid.Column="2" Values="{x:Bind CpuHistory}" Width="40" Height="18" StrokeColor="DodgerBlue" />
                                    <controls:Sparkline Grid.Column="3" Values="{x:Bind MemoryHistory}" Width="40" Height="18" StrokeColor="MediumPurple" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
