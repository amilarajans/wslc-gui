<Page
    x:Class="OrchardWin.App.Views.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:OrchardWin.App.Controls"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <!--
        "Local AI & Sandboxes" is a single NavigationView entry (see MainWindow.xaml), so this
        page hosts its own two-tab strip: "Local Models" (this page's own two-pane content) and
        "Sandboxes" (SandboxesPage, navigated into a nested Frame the first time its tab is
        shown) - the same Frame.Navigate(pageType, servicesInstance) contract MainWindow uses
        for top-level pages, just one level deeper.
    -->
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="20,16,20,8">
            <ToggleButton x:Name="ModelsTabButton" Content="Local Models" IsChecked="True" Click="ModelsTabButton_Click" />
            <ToggleButton x:Name="SandboxesTabButton" Content="Sandboxes" Click="SandboxesTabButton_Click" />
        </StackPanel>

        <Grid Grid.Row="1" x:Name="ContentHost">
            <!-- ================= Local Models tab ================= -->
            <Grid x:Name="ModelsContent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- List pane -->
                <Grid Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="16,4,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Local Models" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="AddButton" Grid.Column="1" Click="AddButton_Click" Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="8" Padding="24" MaxWidth="280">
                            <FontIcon Glyph="&#xE945;" FontSize="34" Opacity="0.6" HorizontalAlignment="Center" />
                            <TextBlock Text="No model servers yet" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="Start one with the + button, or launch Ollama / LM Studio and it will be detected here."
                                       Opacity="0.7" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" />
                            <StackPanel x:Name="EngineHintPanel" Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="Ollama isn't installed" Opacity="0.7" FontSize="11" TextAlignment="Center" />
                                <HyperlinkButton Content="ollama.com/download" NavigateUri="https://ollama.com/download"
                                                  HorizontalAlignment="Center" FontSize="11" Padding="0" />
                            </StackPanel>
                        </StackPanel>

                        <ScrollViewer x:Name="ListScrollViewer">
                            <StackPanel Spacing="4" Padding="0,0,0,12">
                                <StackPanel x:Name="ManagedSection" Spacing="2">
                                    <TextBlock Text="MANAGED BY ORCHARD-WIN" Opacity="0.6" FontSize="11" Padding="16,8,16,2" />
                                    <ListView x:Name="ServersList" SelectionMode="Single" SelectionChanged="ServersList_SelectionChanged" Padding="4,0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ModelRow">
                                                <controls:ListItemRow Icon="&#xE950;" IconColor="{x:Bind IconColor}"
                                                                       PrimaryText="{x:Bind PrimaryText}"
                                                                       SecondaryLeftText="{x:Bind SecondaryText}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>

                                <StackPanel x:Name="DetectedSection" Spacing="2">
                                    <TextBlock Text="DETECTED" Opacity="0.6" FontSize="11" Padding="16,8,16,2" />
                                    <ListView x:Name="ProvidersList" SelectionMode="Single" SelectionChanged="ProvidersList_SelectionChanged" Padding="4,0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ModelRow">
                                                <controls:ListItemRow Icon="&#xE950;" IconColor="{x:Bind IconColor}"
                                                                       PrimaryText="{x:Bind PrimaryText}"
                                                                       SecondaryLeftText="{x:Bind SecondaryText}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Detail pane -->
                <Grid Grid.Column="1">
                    <TextBlock x:Name="DetailEmptyText" Text="Select a model" Opacity="0.6"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <ScrollViewer x:Name="DetailScrollViewer" Visibility="Collapsed">
                        <StackPanel x:Name="DetailPanel" Spacing="14" Padding="24" MaxWidth="640" HorizontalAlignment="Left">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="StatusDot" Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center" />
                                <TextBlock x:Name="DetailTitleText" Grid.Column="1" FontSize="18" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <Border Grid.Column="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="DetailPortText" FontSize="11" Opacity="0.8" />
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="On this Mac" Opacity="0.6" FontSize="12" />
                                <TextBlock x:Name="OnMacUrlText" Grid.Column="1" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                                           IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                            </Grid>

                            <Grid x:Name="ContainerUrlRow" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="From containers" Opacity="0.6" FontSize="12" />
                                <TextBlock x:Name="ContainerUrlText" Grid.Column="1" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                                           IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock x:Name="ContainerUrlCaptionText" Opacity="0.6" FontSize="11" TextWrapping="Wrap" />

                            <StackPanel x:Name="ModelsListSection" Spacing="4">
                                <TextBlock x:Name="ModelsHeaderText" Opacity="0.6" FontSize="12" />
                                <ListView x:Name="ModelsListView" SelectionMode="None" MaxHeight="200">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Cascadia Mono,Consolas" FontSize="12" IsTextSelectionEnabled="True" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                            <TextBlock x:Name="NoModelsText" Text="No models reported" Opacity="0.6" FontSize="12" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ChatButton" Click="ChatButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE945;" FontSize="13" />
                                        <TextBlock Text="Chat…" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="StopButton" Click="StopButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71A;" FontSize="13" />
                                        <TextBlock Text="Stop" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ShowLogButton" Click="ShowLogButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="13" />
                                        <TextBlock Text="Show Log" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock x:Name="FailedText" Text="Stopped unexpectedly" Foreground="Red" FontSize="12" Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ================= Sandboxes tab ================= -->
            <Frame x:Name="SandboxesHostFrame" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
