<Page
    x:Class="OrchardWin.App.Views.MachinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:OrchardWin.App.Controls"
    xmlns:vm="using:OrchardWin.App.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Machines" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" x:Name="ToolbarCreateMachineButton" Content="Create Machine"
                    Click="CreateMachineButton_Click" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <!-- Two-pane: list | detail -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- List pane -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <Grid x:Name="ListStateGrid">
                    <StackPanel x:Name="UnavailablePanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="6" Padding="24" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE950;" FontSize="32" Opacity="0.6" HorizontalAlignment="Center" />
                        <TextBlock Text="Machines Unavailable" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Text="Container machines need the WSL container preview - run wsl --update --pre-release"
                                   FontSize="12" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="8" Visibility="Collapsed">
                        <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center" />
                        <TextBlock Text="Loading machines..." FontSize="12" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="EmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="6" Padding="24" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE950;" FontSize="32" Opacity="0.6" HorizontalAlignment="Center" />
                        <TextBlock Text="No Machines" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="Create a container machine to get started" FontSize="12" Opacity="0.7"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button Content="Create Machine" Click="CreateMachineButton_Click"
                                HorizontalAlignment="Center" Margin="0,4,0,0" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>

                    <ListView x:Name="MachinesListView" SelectionMode="Single"
                              SelectionChanged="MachinesListView_SelectionChanged" Visibility="Collapsed">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MachineRow">
                                <controls:ListItemRow Icon="&#xE950;" IconColor="{x:Bind IconColor}"
                                                       PrimaryText="{x:Bind PrimaryText}"
                                                       SecondaryLeftText="{x:Bind SecondaryLeftText}"
                                                       SecondaryRightText="{x:Bind SecondaryRightText}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Detail pane -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                    Padding="20">
                <Grid x:Name="DetailStateGrid">
                    <TextBlock x:Name="NoSelectionPanel" Text="Select a machine" Opacity="0.6"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <ScrollViewer x:Name="DetailScroll" Visibility="Collapsed">
                        <StackPanel Spacing="20">
                            <!-- Header -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="DetailNameText" FontSize="20" FontWeight="SemiBold" />
                                    <Border x:Name="DefaultBadge" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Visibility="Collapsed">
                                        <TextBlock Text="DEFAULT" FontSize="10" FontWeight="Bold" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="DetailStatusText" FontSize="12" />
                            </StackPanel>

                            <!-- Lifecycle actions -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="BootButton" Content="Boot" Click="BootButton_Click"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" />
                                <Button x:Name="SetDefaultButton" Content="Set Default" Click="SetDefaultButton_Click" />
                                <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click" />
                            </StackPanel>

                            <!-- Field dump -->
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Image" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailImageText" Grid.Column="1" FontSize="12"
                                                   TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Platform" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailPlatformText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="CPUs" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailCpusText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Memory" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailMemoryText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Disk" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailDiskText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Home Mount" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailHomeMountText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nested Virt" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailVirtText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="IP Address" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailIpText" Grid.Column="1" FontSize="12"
                                                   FontFamily="Cascadia Mono,Consolas" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="User" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailUserText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Container ID" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailContainerIdText" Grid.Column="1" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" FontFamily="Cascadia Mono,Consolas" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Initialized" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailInitializedText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Created" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailCreatedText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Started" Opacity="0.6" FontSize="12" />
                                        <TextBlock x:Name="DetailStartedText" Grid.Column="1" FontSize="12" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Editable boot configuration -->
                            <StackPanel Spacing="12">
                                <TextBlock Text="Boot Configuration" FontSize="16" FontWeight="SemiBold" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Grid.Column="0" x:Name="EditCpusBox" Header="CPUs"
                                               SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="1" Minimum="1" />
                                    <NumberBox Grid.Column="1" x:Name="EditMemoryBox" Header="Memory (GB)"
                                               SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="1" Minimum="1" />
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Home Directory Mount" FontSize="13" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <RadioButton x:Name="EditHomeMountRwRadio" Content="Read/Write" GroupName="EditHomeMount" />
                                        <RadioButton x:Name="EditHomeMountRoRadio" Content="Read-Only" GroupName="EditHomeMount" />
                                        <RadioButton x:Name="EditHomeMountNoneRadio" Content="None" GroupName="EditHomeMount" />
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox x:Name="EditVirtualizationCheck" Content="Enable nested virtualization" />

                                <CheckBox x:Name="RestartNowCheck" Content="Restart now to apply changes" />

                                <TextBlock x:Name="ApplyErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" />

                                <Button x:Name="ApplyButton" Content="Apply" Click="ApplyButton_Click"
                                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
