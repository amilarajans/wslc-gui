<ContentDialog
    x:Class="OrchardWin.App.Views.AddDnsDomainDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Add DNS Domain"
    PrimaryButtonText="Add Domain"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <StackPanel Spacing="8" Width="440">
        <TextBlock Text="Domain Name" FontWeight="SemiBold" />
        <TextBox x:Name="DomainBox" PlaceholderText="e.g., local.dev, myapp.local" TextChanged="OnDomainChanged" />
        <TextBlock Text="Enter a domain name for local container networking. This requires administrator privileges."
                   FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
        <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" />
    </StackPanel>
</ContentDialog>
