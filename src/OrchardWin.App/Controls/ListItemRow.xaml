<UserControl
    x:Class="OrchardWin.App.Controls.ListItemRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        A single selectable list row: a status-colored glyph, a primary label, up to two
        secondary labels (left/right), and an optional "sandbox" badge. Reused by every
        Containers/Images/Machines/Networks/DNS/Models list - the WinUI analogue of Orchard's
        shared `ListItemRow` SwiftUI component.
    -->
    <Grid Padding="6,4" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <FontIcon x:Name="IconGlyph" Grid.Column="0" FontSize="14" VerticalAlignment="Center" />

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
            <TextBlock x:Name="PrimaryTextBlock" TextTrimming="CharacterEllipsis" FontSize="13" />
            <TextBlock x:Name="SecondaryLeftTextBlock" TextTrimming="CharacterEllipsis" FontSize="11"
                       Opacity="0.65" Visibility="Collapsed" />
        </StackPanel>

        <Border x:Name="SandboxBadge" Grid.Column="2" Background="{ThemeResource SystemFillColorCautionBrush}"
                CornerRadius="4" Padding="6,1" Margin="0,0,4,0" Visibility="Collapsed" VerticalAlignment="Center">
            <TextBlock Text="Sandbox" FontSize="10" FontWeight="SemiBold" />
        </Border>

        <TextBlock x:Name="SecondaryRightTextBlock" Grid.Column="3" FontSize="11" Opacity="0.65"
                   VerticalAlignment="Center" Visibility="Collapsed" />
    </Grid>
</UserControl>
