<UserControl
    x:Class="OrchardWin.App.Controls.Sparkline"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    MinHeight="20" MinWidth="40">

    <Grid x:Name="RootGrid" SizeChanged="OnSizeChanged">
        <!-- Soft glow under the stroke -->
        <Path x:Name="Glow" StrokeThickness="3.2" />
        <!-- Smooth Catmull–Rom stroke -->
        <Path x:Name="Line" StrokeThickness="1.6" />
    </Grid>
</UserControl>
