<UserControl
    x:Class="OrchardWin.App.Controls.Sparkline"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- A minimal auto-scaling line sparkline, redrawn whenever Values/ActualSize changes.
         The WinUI analogue of Orchard's Canvas-drawn HistoryBars, using a Polyline instead of
         individual bars - simpler to keep smooth at row-sparkline sizes (~60x20). -->
    <Grid x:Name="RootGrid" SizeChanged="OnSizeChanged">
        <Polyline x:Name="Line" StrokeThickness="1.5" StrokeLineJoin="Round" />
    </Grid>
</UserControl>
